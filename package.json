{
  "name": "rev",
  "private": true,
  "packageManager": "bun@1.3.4",
  "workspaces": {
    "packages": ["apps/*", "packages/*"],
    "catalog": {
      "react": "^19.1.0",
      "react-dom": "^19.1.0",
      "@types/react": "^19.1.0",
      "@types/react-dom": "^19.1.0",
      "typescript": "^5.7.0",
      "tailwindcss": "^4.1.0",
      "clsx": "^2.1.1",
      "tailwind-merge": "^3.3.0",
      "vite": "^6.3.0"
    }
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "dev:web": "cd apps/web && bun run dev",
    "dev:server": "cd apps/server && bun run dev",
    "dev:desktop": "concurrently --kill-others \"bun run dev:web\" \"bun run dev:server\" \"sleep 3 && cd apps/desktop && bunx tauri dev\"",
    "dist": "cd apps/desktop && bunx tauri build",
    "dist:debug": "cd apps/desktop && bunx tauri build --debug",
    "dev:app": "cd packages/app && bun run dev",
    "dev:electrobun": "concurrently --kill-others \"bun run dev:app\" \"sleep 3 && cd apps/desktop-electrobun && bun run dev\"",
    "clean": "rm -rf apps/web/build apps/web/.svelte-kit apps/server/dist apps/desktop/target .turbo",
    "postinstall": "echo '\\n  Run `bun run dev` to start developing, or `bun run dist` to build an installer.\\n'"
  },
  "devDependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@tauri-apps/cli": "^2",
    "concurrently": "^9.2.1",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@pierre/diffs": "^1.1.15"
  }
}
