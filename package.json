{
  "name": "rev",
  "private": true,
  "packageManager": "bun@1.3.4",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "dev:web": "cd apps/web && bun run dev",
    "dev:server": "cd apps/server && bun run dev",
    "dev:desktop": "concurrently --kill-others \"bun run dev:web\" \"bun run dev:server\" \"sleep 3 && cd apps/desktop && bunx tauri dev\"",
    "dist": "cd apps/desktop && bunx tauri build",
    "dist:debug": "cd apps/desktop && bunx tauri build --debug",
    "clean": "rm -rf apps/web/build apps/web/.svelte-kit apps/server/dist apps/desktop/target .turbo",
    "postinstall": "echo '\\n  Run `bun run dev` to start developing, or `bun run dist` to build an installer.\\n'"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "concurrently": "^9.2.1",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@pierre/diffs": "^1.1.15"
  }
}
