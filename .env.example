# Revv — Environment Variables
# Copy this file to .env and fill in your values.
# Bun automatically loads .env files.

# Required
# GitHub OAuth App credentials
# Create one at: https://github.com/settings/developers
#   - Application name: Revv (local dev)
#   - Homepage URL: http://localhost:5173
#   - Authorization callback URL: http://localhost:45678/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
BETTER_AUTH_SECRET=   # Generate with: openssl rand -hex 32

# Optional
REVV_DB_PATH=./revv.db   # Custom database file path
REV_DEBUG=false           # Enable debug logging
