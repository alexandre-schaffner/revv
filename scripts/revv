#!/usr/bin/env bash
# ──────────────────────────────────────────────────────────────
# revv — Management CLI for a Revv source install
#
# Installed by scripts/install-macos.sh to ~/.local/bin/revv.
# Drives the source tree at ~/Library/Application Support/Revv/src
# and the LaunchAgent at ~/Library/LaunchAgents/com.revv.server.plist.
#
# Commands:
#   revv update      Pull latest, rebuild, reinstall, reload service
#   revv uninstall   Remove app, source, LaunchAgent, and this CLI
#   revv start       Load + start the server LaunchAgent
#   revv stop        Unload + stop the server LaunchAgent
#   revv restart     Stop + start
#   revv status      Show versions, install paths, server state
#   revv logs        Tail the server logs
#   revv open        Open Revv.app
#   revv doctor      Run a set of health checks
#   revv path        Print paths used by this install
#   revv help        Show this message
# ──────────────────────────────────────────────────────────────
set -euo pipefail

CONFIG_FILE="$HOME/Library/Application Support/Revv/config"
INSTALL_DIR="${REVV_INSTALL_DIR:-$HOME/Library/Application Support/Revv/src}"
APP_CANDIDATES=(
  "/Applications/Revv.app"
  "$HOME/Applications/Revv.app"
)
LAUNCH_AGENT_LABEL="com.revv.server"
LAUNCH_AGENT_PLIST="$HOME/Library/LaunchAgents/$LAUNCH_AGENT_LABEL.plist"
LOG_DIR="$HOME/Library/Logs/Revv"
CLI_PATH="$HOME/.local/bin/revv"
API_URL="http://localhost:45678"

# Override defaults with values persisted by the installer.
if [[ -f "$CONFIG_FILE" ]]; then
  # shellcheck disable=SC1090
  source "$CONFIG_FILE"
  [[ -n "${SOURCE_DIR:-}" ]] && INSTALL_DIR="$SOURCE_DIR"
  [[ -n "${APP_PATH:-}" && -d "$APP_PATH" ]] && APP_CANDIDATES=("$APP_PATH" "${APP_CANDIDATES[@]}")
fi

# ── Colors ───────────────────────────────────────────────────
if [[ -t 1 ]]; then
  RED=$'\033[0;31m'; GREEN=$'\033[0;32m'; YELLOW=$'\033[1;33m'
  BLUE=$'\033[0;34m'; CYAN=$'\033[0;36m'; BOLD=$'\033[1m'
  DIM=$'\033[2m'; RESET=$'\033[0m'
else
  RED=""; GREEN=""; YELLOW=""; BLUE=""; CYAN=""; BOLD=""; DIM=""; RESET=""
fi

info()    { printf "%s[info]%s  %s\n" "$BLUE" "$RESET" "$*"; }
success() { printf "%s[  ok]%s  %s\n" "$GREEN" "$RESET" "$*"; }
warn()    { printf "%s[warn]%s  %s\n" "$YELLOW" "$RESET" "$*"; }
fail()    { printf "%s[FAIL]%s  %s\n" "$RED" "$RESET" "$*" >&2; exit 1; }
step()    { printf "\n%s%s▸ %s%s\n" "$BOLD" "$CYAN" "$*" "$RESET"; }

confirm() {
  local reply
  printf "%s  → %s [y/N] %s" "$YELLOW" "$1" "$RESET"
  read -r reply
  [[ "$reply" =~ ^[Yy] ]]
}

find_app() {
  for p in "${APP_CANDIDATES[@]}"; do
    [[ -d "$p" ]] && { printf "%s" "$p"; return 0; }
  done
  return 1
}

ensure_install_dir() {
  [[ -d "$INSTALL_DIR/.git" ]] || fail "No Revv source install found at $INSTALL_DIR.
Run the installer first:
  curl -fsSL https://raw.githubusercontent.com/alexandre-schaffner/revv/main/scripts/install-macos.sh | bash"
}

load_bun_path() {
  [[ -d "$HOME/.bun/bin" ]] && export PATH="$HOME/.bun/bin:$PATH"
  [[ -f "$HOME/.cargo/env" ]] && { # shellcheck disable=SC1091
    source "$HOME/.cargo/env"; }
}

server_running() {
  # Port check — more reliable than launchctl state
  nc -z 127.0.0.1 45678 >/dev/null 2>&1
}

# ── Commands ─────────────────────────────────────────────────

cmd_help() {
  cat <<EOF
${BOLD}revv${RESET} — manage your Revv source install.

${BOLD}Usage:${RESET}
  revv <command>

${BOLD}Commands:${RESET}
  ${CYAN}update${RESET}      Pull latest code, rebuild, reinstall, reload server
  ${CYAN}uninstall${RESET}   Remove the app, the source tree, the LaunchAgent, and this CLI
  ${CYAN}start${RESET}       Start the background API server
  ${CYAN}stop${RESET}        Stop the background API server
  ${CYAN}restart${RESET}     Restart the background API server
  ${CYAN}status${RESET}      Show install paths, versions, and server state
  ${CYAN}logs${RESET}        Tail the server log files
  ${CYAN}open${RESET}        Launch Revv.app
  ${CYAN}doctor${RESET}      Run health checks
  ${CYAN}path${RESET}        Print the paths this install uses
  ${CYAN}help${RESET}        Show this message
EOF
}

cmd_path() {
  cat <<EOF
Source:        $INSTALL_DIR
App:           $(find_app || printf "(not installed)")
LaunchAgent:   $LAUNCH_AGENT_PLIST
Logs:          $LOG_DIR
CLI:           $CLI_PATH
EOF
}

cmd_start() {
  [[ -f "$LAUNCH_AGENT_PLIST" ]] || fail "LaunchAgent missing at $LAUNCH_AGENT_PLIST. Re-run the installer."
  launchctl load -w "$LAUNCH_AGENT_PLIST" 2>/dev/null || true
  sleep 1
  if server_running; then success "Server is running on $API_URL"; else warn "Server did not come up — check 'revv logs'"; fi
}

cmd_stop() {
  launchctl unload -w "$LAUNCH_AGENT_PLIST" 2>/dev/null || true
  sleep 1
  if server_running; then warn "Server still responds — another process may be on port 45678"; else success "Server stopped"; fi
}

cmd_restart() {
  cmd_stop
  cmd_start
}

cmd_status() {
  step "Revv install status"
  ensure_install_dir 2>/dev/null || { warn "Source not found at $INSTALL_DIR"; return 0; }

  local commit branch
  commit="$(git -C "$INSTALL_DIR" rev-parse --short HEAD 2>/dev/null || echo unknown)"
  branch="$(git -C "$INSTALL_DIR" rev-parse --abbrev-ref HEAD 2>/dev/null || echo unknown)"
  printf "  %sSource:%s      %s\n" "$BOLD" "$RESET" "$INSTALL_DIR"
  printf "  %sBranch:%s      %s @ %s\n" "$BOLD" "$RESET" "$branch" "$commit"

  if app="$(find_app)"; then
    local ver
    ver="$(/usr/libexec/PlistBuddy -c 'Print :CFBundleShortVersionString' "$app/Contents/Info.plist" 2>/dev/null || echo "?")"
    printf "  %sApp:%s         %s (v%s)\n" "$BOLD" "$RESET" "$app" "$ver"
  else
    printf "  %sApp:%s         %s(not installed)%s\n" "$BOLD" "$RESET" "$RED" "$RESET"
  fi

  if [[ -f "$LAUNCH_AGENT_PLIST" ]]; then
    local pid
    pid="$(launchctl list 2>/dev/null | awk -v lbl="$LAUNCH_AGENT_LABEL" '$3 == lbl {print $1}')"
    if [[ -n "$pid" && "$pid" != "-" ]]; then
      printf "  %sService:%s     running (pid %s)\n" "$BOLD" "$RESET" "$pid"
    else
      printf "  %sService:%s     loaded but not running\n" "$BOLD" "$RESET"
    fi
  else
    printf "  %sService:%s     %snot installed%s\n" "$BOLD" "$RESET" "$RED" "$RESET"
  fi

  if server_running; then
    printf "  %sAPI:%s         %sresponding on %s%s\n" "$BOLD" "$RESET" "$GREEN" "$API_URL" "$RESET"
  else
    printf "  %sAPI:%s         %snot responding on %s%s\n" "$BOLD" "$RESET" "$RED" "$API_URL" "$RESET"
  fi

  # Upstream check
  if git -C "$INSTALL_DIR" fetch --quiet 2>/dev/null; then
    local behind
    behind="$(git -C "$INSTALL_DIR" rev-list --count "HEAD..@{upstream}" 2>/dev/null || echo 0)"
    if [[ "$behind" -gt 0 ]]; then
      printf "  %sUpdate:%s      %s%d commit(s) behind — run 'revv update'%s\n" "$BOLD" "$RESET" "$YELLOW" "$behind" "$RESET"
    else
      printf "  %sUpdate:%s      up to date\n" "$BOLD" "$RESET"
    fi
  fi
}

cmd_logs() {
  [[ -d "$LOG_DIR" ]] || fail "No log directory at $LOG_DIR"
  local files=()
  [[ -f "$LOG_DIR/server.err.log" ]] && files+=("$LOG_DIR/server.err.log")
  [[ -f "$LOG_DIR/server.out.log" ]] && files+=("$LOG_DIR/server.out.log")
  [[ ${#files[@]} -gt 0 ]] || fail "No log files yet. Start the server with 'revv start'."
  printf "%sTailing %s%s — Ctrl-C to exit%s\n" "$DIM" "${files[*]}" "" "$RESET"
  tail -F "${files[@]}"
}

cmd_open() {
  local app
  app="$(find_app)" || fail "Revv.app not found. Run 'revv update' or reinstall."
  open "$app"
}

cmd_update() {
  ensure_install_dir
  load_bun_path
  step "Updating Revv"

  info "Fetching from origin"
  git -C "$INSTALL_DIR" fetch --all --prune

  local before after branch
  branch="$(git -C "$INSTALL_DIR" rev-parse --abbrev-ref HEAD)"
  before="$(git -C "$INSTALL_DIR" rev-parse HEAD)"
  git -C "$INSTALL_DIR" reset --hard "origin/$branch"
  after="$(git -C "$INSTALL_DIR" rev-parse HEAD)"

  if [[ "$before" == "$after" ]]; then
    info "Already up to date ($(git -C "$INSTALL_DIR" rev-parse --short HEAD))"
    if ! confirm "Force a rebuild anyway?"; then
      success "Nothing to do."
      return 0
    fi
  else
    info "Updated $before → $after"
    info "Changes:"
    git -C "$INSTALL_DIR" --no-pager log --oneline "$before..$after" | sed 's/^/    /'
  fi

  info "Installing dependencies"
  (cd "$INSTALL_DIR" && bun install)

  info "Building (make dist)"
  (cd "$INSTALL_DIR" && make dist)

  # Find the newly built .app and copy it over the installed one
  local bundle_app
  bundle_app="$INSTALL_DIR/apps/desktop/target/release/bundle/macos/Revv.app"
  if [[ ! -d "$bundle_app" ]]; then
    bundle_app="$(find "$INSTALL_DIR/apps/desktop/target" -maxdepth 6 -type d -name 'Revv.app' -path '*/bundle/macos/*' 2>/dev/null | head -1)"
  fi
  [[ -d "$bundle_app" ]] || fail "Build finished but Revv.app was not produced."

  # Replace the installed .app (prefer the same location it was at).
  local dest_app
  dest_app="$(find_app)" || dest_app="/Applications/Revv.app"
  local dest_dir
  dest_dir="$(dirname "$dest_app")"
  if [[ ! -w "$dest_dir" ]]; then
    warn "$dest_dir is not writable — falling back to ~/Applications"
    dest_dir="$HOME/Applications"
    mkdir -p "$dest_dir"
    dest_app="$dest_dir/Revv.app"
  fi

  info "Quitting Revv if it's running"
  osascript -e 'tell application "Revv" to quit' 2>/dev/null || true
  sleep 1

  info "Replacing $dest_app"
  rm -rf "$dest_app"
  cp -R "$bundle_app" "$dest_app"
  xattr -cr "$dest_app" 2>/dev/null || true

  info "Reloading server LaunchAgent"
  launchctl unload "$LAUNCH_AGENT_PLIST" 2>/dev/null || true
  launchctl load -w "$LAUNCH_AGENT_PLIST" 2>/dev/null || true

  # Refresh the CLI itself in case it changed upstream.
  if [[ -f "$INSTALL_DIR/scripts/revv" ]]; then
    cp "$INSTALL_DIR/scripts/revv" "$CLI_PATH"
    chmod +x "$CLI_PATH"
  fi

  success "Updated to $(git -C "$INSTALL_DIR" rev-parse --short HEAD)"
  open "$dest_app" || true
}

cmd_uninstall() {
  step "Uninstall Revv"
  cat <<EOF
This will remove:
  • /Applications/Revv.app (or ~/Applications/Revv.app)
  • $INSTALL_DIR
  • $LAUNCH_AGENT_PLIST
  • $LOG_DIR
  • $CLI_PATH
EOF
  confirm "Proceed with uninstall?" || { info "Aborted."; return 0; }

  # Stop the server and unregister the agent.
  launchctl unload -w "$LAUNCH_AGENT_PLIST" 2>/dev/null || true
  rm -f "$LAUNCH_AGENT_PLIST"

  # Quit and remove the .app
  osascript -e 'tell application "Revv" to quit' 2>/dev/null || true
  sleep 1
  for p in "${APP_CANDIDATES[@]}"; do
    [[ -d "$p" ]] && rm -rf "$p"
  done

  # Remove source and logs
  rm -rf "$INSTALL_DIR" "$LOG_DIR"

  # Remove self — do this last so the script can finish executing.
  if [[ -f "$CLI_PATH" ]]; then
    rm -f "$CLI_PATH"
  fi

  success "Revv has been uninstalled."
  info "Note: Bun and the Rust toolchain were left installed — remove them manually if you no longer need them."
}

cmd_doctor() {
  step "Revv doctor"
  local issues=0
  bump() { issues=$((issues + 1)); }

  if [[ -d "$INSTALL_DIR/.git" ]]; then success "Source tree present"; else warn "Source tree missing: $INSTALL_DIR"; bump; fi
  if find_app >/dev/null; then success "Revv.app installed: $(find_app)"; else warn "Revv.app not found"; bump; fi
  if [[ -f "$LAUNCH_AGENT_PLIST" ]]; then success "LaunchAgent installed"; else warn "LaunchAgent missing"; bump; fi
  if command -v bun >/dev/null 2>&1; then success "bun $(bun --version)"; else warn "bun not on PATH"; bump; fi
  if command -v cargo >/dev/null 2>&1; then success "cargo $(cargo --version | awk '{print $2}')"; else warn "cargo not on PATH"; bump; fi
  if server_running; then success "API server responding on $API_URL"; else warn "API server not responding — try 'revv restart'"; bump; fi
  if [[ -f "$INSTALL_DIR/.env" ]]; then
    if grep -q '^GITHUB_CLIENT_ID=..*' "$INSTALL_DIR/.env" \
       && grep -q '^GITHUB_CLIENT_SECRET=..*' "$INSTALL_DIR/.env" \
       && grep -q '^BETTER_AUTH_SECRET=..*' "$INSTALL_DIR/.env"; then
      success ".env has all required values"
    else
      warn ".env is missing one or more required values"
      bump
    fi
  else
    warn ".env missing at $INSTALL_DIR/.env"
    bump
  fi

  printf "\n"
  if [[ $issues -eq 0 ]]; then
    printf "%s%s  ✓  All checks passed%s\n" "$BOLD" "$GREEN" "$RESET"
  else
    printf "%s%s  ✗  %d issue(s) found%s\n" "$BOLD" "$YELLOW" "$issues" "$RESET"
    return 1
  fi
}

# ── Dispatch ─────────────────────────────────────────────────
case "${1:-help}" in
  update)     cmd_update ;;
  uninstall)  cmd_uninstall ;;
  start)      cmd_start ;;
  stop)       cmd_stop ;;
  restart)    cmd_restart ;;
  status)     cmd_status ;;
  logs)       cmd_logs ;;
  open)       cmd_open ;;
  doctor)     cmd_doctor ;;
  path)       cmd_path ;;
  help|-h|--help) cmd_help ;;
  *)
    printf "Unknown command: %s\n\n" "$1" >&2
    cmd_help
    exit 2
    ;;
esac
