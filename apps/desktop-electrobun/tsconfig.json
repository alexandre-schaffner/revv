{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "exactOptionalPropertyTypes": false,
    "paths": {
      "~/*": ["./src/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "electrobun.config.ts",
    "vite.config.ts"
  ],
  "exclude": ["node_modules", "dist", "build"]
}
